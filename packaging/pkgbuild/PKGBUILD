pkgname=switcharoo
# x-release-please-start-version
pkgver=4.9.2
# x-release-please-end
pkgrel=1
pkgdesc="A modern GTK4-based window switcher for Hyprland"
arch=('x86_64' 'aarch64')
conflicts=('switcharoo')
provides=('switcharoo')
url="https://github.com/h3rmt/switcharoo/"
license=("MIT")
makedepends=('cargo')
depends=('hyprland' 'gtk4-layer-shell' 'gtk4' 'gcc' 'pixman' 'libadwaita' 'zstd')
source=("switcharoo-$pkgver.tar.gz::https://static.crates.io/crates/switcharoo/switcharoo-$pkgver.crate")

prepare() {
    export RUSTUP_TOOLCHAIN=stable
    cd "switcharoo-$pkgver"
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cd "switcharoo-$pkgver"
    cargo build --frozen --release
}

package() {
    install -Dm755 "switcharoo-$pkgver/target/release/switcharoo"             "$pkgdir/usr/bin/switcharoo"
    install -Dm644 "switcharoo-$pkgver/LICENSE"                              "$pkgdir/usr/share/licenses/switcharoo/LICENSE"
    install -Dm644 "switcharoo-$pkgver/README.md"                            "$pkgdir/usr/share/doc/switcharoo/README.md"
    install -Dm644 "switcharoo-$pkgver/docs/CONFIGURE.md"                    "$pkgdir/usr/share/doc/switcharoo/CONFIGURE.md"
    install -Dm644 "switcharoo-$pkgver/docs/DEBUG.md"                        "$pkgdir/usr/share/doc/switcharoo/DEBUG.md"
    install -Dm644 "switcharoo-$pkgver/packaging/switcharoo.service"          "$pkgdir/usr/lib/systemd/user/switcharoo.service"
    install -Dm644 "switcharoo-$pkgver/packaging/switcharoo-settings.png"     "$pkgdir/usr/share/pixmaps/switcharoo.png"
    install -Dm644 "switcharoo-$pkgver/packaging/switcharoo-settings.desktop" "$pkgdir/usr/share/applications/switcharoo-settings.desktop"

    mkdir "$pkgdir/usr/share/switcharoo"
    tar -xvf "switcharoo-$pkgver/packaging/usr-share.tar" -C "$pkgdir/usr/share/switcharoo"

    "$pkgdir/usr/bin/switcharoo" completions bash -p  "$pkgdir/usr/share/bash-completion/completions"
    "$pkgdir/usr/bin/switcharoo" completions fish -p  "$pkgdir/usr/share/fish/vendor_completions.d"
    "$pkgdir/usr/bin/switcharoo" completions zsh -p   "$pkgdir/usr/share/zsh/site-functions"
}
