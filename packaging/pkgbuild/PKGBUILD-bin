pkgname=switcharoo-bin
# x-release-please-start-version
pkgver=4.9.2
# x-release-please-end
pkgrel=1
pkgdesc="A modern GTK4-based window switcher for Hyprland (binary release)"
arch=('x86_64' 'aarch64')
conflicts=('switcharoo')
provides=('switcharoo')
url="https://github.com/h3rmt/switcharoo/"
license=("MIT")
depends=('hyprland' 'gtk4-layer-shell' 'gtk4' 'gcc' 'pixman' 'libadwaita' 'zstd')
source_x86_64=("https://github.com/H3rmt/switcharoo/releases/download/v$pkgver/switcharoo-$pkgver-x86_64.tar.zst")
source_aarch64=("https://github.com/H3rmt/switcharoo/releases/download/v$pkgver/switcharoo-$pkgver-aarch64.tar.zst")

package() {
    install -Dm755 "switcharoo"                  "$pkgdir/usr/bin/switcharoo"
    install -Dm644 "LICENSE"                    "$pkgdir/usr/share/licenses/switcharoo/LICENSE"
    install -Dm644 "README.md"                  "$pkgdir/usr/share/doc/switcharoo/README.md"
    install -Dm644 "CONFIGURE.md"               "$pkgdir/usr/share/doc/switcharoo/CONFIGURE.md"
    install -Dm644 "DEBUG.md"                   "$pkgdir/usr/share/doc/switcharoo/DEBUG.md"
    install -Dm644 "switcharoo.service"          "$pkgdir/usr/lib/systemd/user/switcharoo.service"
    install -Dm644 "switcharoo-settings.png"     "$pkgdir/usr/share/pixmaps/switcharoo.png"
    install -Dm644 "switcharoo-settings.desktop" "$pkgdir/usr/share/applications/switcharoo-settings.desktop"

    mkdir "$pkgdir/usr/share/switcharoo"
    tar -xvf "usr-share.tar" -C "$pkgdir/usr/share/switcharoo"

    "$pkgdir/usr/bin/switcharoo" completions bash -p  "$pkgdir/usr/share/bash-completion/completions"
    "$pkgdir/usr/bin/switcharoo" completions fish -p  "$pkgdir/usr/share/fish/vendor_completions.d"
    "$pkgdir/usr/bin/switcharoo" completions zsh -p   "$pkgdir/usr/share/zsh/site-functions"
}
